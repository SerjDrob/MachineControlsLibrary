<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MachineControlsLibrary.Controls.ContentCheckBox">
    <Style TargetType="{x:Type local:ContentToggleCheckBox}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ContentToggleCheckBox}">
                    <!--  Background гарантирует, что вся область будет реагировать на клики  -->
                    <Border
                        x:Name="Root"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter
                                x:Name="UncheckedPresenter"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding UncheckedContent}"
                                Visibility="Visible" />

                            <ContentPresenter
                                x:Name="CheckedPresenter"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding CheckedContent}"
                                Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!--  Переключение состояний  -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="UncheckedPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="CheckedPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!--  Обработка null-состояния (IsThreeState)  -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="UncheckedPresenter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="CheckedPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Опционально: визуальный отклик при наведении  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>