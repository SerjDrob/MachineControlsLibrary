<UserControl
    x:Class="MachineControlsLibrary.CommonDialog.CommonDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border
        Background="{DynamicResource RegionBrush}"
        BorderBrush="{StaticResource PrimaryBrush}"
        BorderThickness="1"
        CornerRadius="12">
        <hc:SimpleStackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="Title"
                    Margin="20,0,20,0"
                    HorizontalAlignment="Center"
                    Style="{StaticResource TextBlockTitleBold}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button
                        Width="22"
                        Height="22"
                        Margin="0,0,4,0"
                        Padding="0"
                        hc:IconElement.Geometry="{StaticResource SuccessGeometry}"
                        Command="hc:ControlCommands.Confirm"
                        Foreground="{DynamicResource SuccessBrush}"
                        Style="{StaticResource ButtonIcon}" />
                    <Button
                        Width="22"
                        Height="22"
                        Margin="0,0,2,0"
                        Padding="0"
                        hc:IconElement.Geometry="{StaticResource ErrorGeometry}"
                        Command="hc:ControlCommands.Cancel"
                        Foreground="{DynamicResource DangerBrush}"
                        Style="{StaticResource ButtonIcon}" />

                </StackPanel>
            </Grid>
            <hc:Divider Margin="2" Orientation="Horizontal" />
            <ContentControl Margin="10" Content="{Binding}" />
        </hc:SimpleStackPanel>
    </Border>
</UserControl>
